{"aggregate_id": "01KS7JM3HSNXGCWV2E9X3JGAEP", "aggregate_type": "Mission", "event_id": "01KS7JM3NQR038FZEXXE74E9BZ", "event_type": "MissionCreated", "payload": {"created_at": "2026-05-22T10:10:16.762124+00:00", "friendly_name": "Canonical Producer Contracts and Legacy Envelope Compatibility", "mission_id": "01KS7JM3HSNXGCWV2E9X3JGAEP", "mission_number": null, "mission_slug": "canonical-producer-contracts-legacy-envelope-01KS7JM3", "mission_type": "software-dev", "purpose_context": "spec-kitty-events is the single source of truth for SaaS-bound event contracts. Today, validate_event() does not call validate_transition() on WPStatusChanged, seven CLI-emitted event types have no published contracts, and there is no canonical legacy-envelope normalization surface. Without closing these gaps, Phase 2 (CLI canonical producer refactor) cannot be enforced and Phase 3 (SaaS explicit legacy normalization) cannot replace the silent strict-envelope carve-out. This mission ships the contracts so the next two phases can land safely.", "purpose_tldr": "Close the conformance and legacy-envelope gaps that block the CLI producer refactor and SaaS legacy adapter.", "target_branch": "kitty/pr/1198-canonical-producer-contracts", "wp_count": 0}, "project_slug": "spec-kitty-events", "project_uuid": "bebf8d60-7c5d-4459-94b6-e0f3e4ad83f9", "schema_version": "5.0.0", "timestamp": "2026-05-22T10:10:16.887903+00:00"}
