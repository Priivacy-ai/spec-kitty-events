{
  "$id": "spec-kitty-events/default_channel_ref",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Reference to the default Slack channel for a teamspace.",
  "properties": {
    "channel_id": {
      "description": "Slack channel identifier",
      "minLength": 1,
      "title": "Channel Id",
      "type": "string"
    },
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Human-readable channel name",
      "title": "Name"
    }
  },
  "required": [
    "channel_id"
  ],
  "title": "DefaultChannelRef",
  "type": "object"
}
