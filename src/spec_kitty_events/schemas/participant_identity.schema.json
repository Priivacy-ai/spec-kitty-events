{
  "$defs": {
    "ParticipantExternalRefs": {
      "additionalProperties": false,
      "description": "Optional cross-channel identity references for a ParticipantIdentity.",
      "properties": {
        "slack_team_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slack Team Id"
        },
        "slack_user_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Slack User Id"
        },
        "teamspace_member_id": {
          "anyOf": [
            {
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Teamspace Member Id"
        }
      },
      "title": "ParticipantExternalRefs",
      "type": "object"
    }
  },
  "$id": "spec-kitty-events/participant_identity",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "SaaS-minted, mission-scoped participant identity.",
  "properties": {
    "display_name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Human-readable name for display",
      "title": "Display Name"
    },
    "external_refs": {
      "anyOf": [
        {
          "$ref": "#/$defs/ParticipantExternalRefs"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Optional cross-channel identity references (V1)"
    },
    "participant_id": {
      "description": "SaaS-minted, mission-scoped unique identifier",
      "minLength": 1,
      "title": "Participant Id",
      "type": "string"
    },
    "participant_type": {
      "description": "Participant category",
      "enum": [
        "human",
        "llm_context"
      ],
      "title": "Participant Type",
      "type": "string"
    },
    "session_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "SaaS-issued session identifier",
      "title": "Session Id"
    }
  },
  "required": [
    "participant_id",
    "participant_type"
  ],
  "title": "ParticipantIdentity",
  "type": "object"
}
