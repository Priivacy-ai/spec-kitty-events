{
  "$id": "spec-kitty-events/thread_ref",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Reference to a Slack thread.",
  "properties": {
    "channel_id": {
      "description": "Slack channel identifier",
      "minLength": 1,
      "title": "Channel Id",
      "type": "string"
    },
    "slack_team_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Slack workspace team identifier",
      "title": "Slack Team Id"
    },
    "thread_ts": {
      "description": "Thread timestamp (Slack ts format)",
      "minLength": 1,
      "title": "Thread Ts",
      "type": "string"
    },
    "url": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Permalink URL to the thread",
      "title": "Url"
    }
  },
  "required": [
    "channel_id",
    "thread_ts"
  ],
  "title": "ThreadRef",
  "type": "object"
}
