{
  "$id": "spec-kitty-events/retrospective_skipped_payload",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Payload for RetrospectiveSkipped events.\n\nEmitted when a retrospective step is explicitly skipped.",
  "properties": {
    "actor": {
      "description": "Actor who decided to skip",
      "minLength": 1,
      "title": "Actor",
      "type": "string"
    },
    "mission_id": {
      "description": "Mission identifier",
      "minLength": 1,
      "title": "Mission Id",
      "type": "string"
    },
    "skip_reason": {
      "description": "Why the retrospective was skipped",
      "minLength": 1,
      "title": "Skip Reason",
      "type": "string"
    },
    "skipped_at": {
      "description": "ISO 8601 skip decision timestamp",
      "minLength": 1,
      "title": "Skipped At",
      "type": "string"
    },
    "trigger_source": {
      "description": "What would have initiated the retrospective",
      "enum": [
        "runtime",
        "operator",
        "policy"
      ],
      "title": "Trigger Source",
      "type": "string"
    }
  },
  "required": [
    "mission_id",
    "actor",
    "trigger_source",
    "skip_reason",
    "skipped_at"
  ],
  "title": "RetrospectiveSkippedPayload",
  "type": "object"
}
