{
  "$id": "spec-kitty-events/teamspace_ref",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Reference to a Slack-connected teamspace.",
  "properties": {
    "name": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Human-readable teamspace name",
      "title": "Name"
    },
    "teamspace_id": {
      "description": "Teamspace identifier",
      "minLength": 1,
      "title": "Teamspace Id",
      "type": "string"
    }
  },
  "required": [
    "teamspace_id"
  ],
  "title": "TeamspaceRef",
  "type": "object"
}
