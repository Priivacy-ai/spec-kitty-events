{
  "$id": "spec-kitty-events/mission_created_payload",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Typed payload for MissionCreated catalog events.",
  "properties": {
    "created_at": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Mission creation timestamp",
      "title": "Created At"
    },
    "friendly_name": {
      "description": "Human-friendly mission title",
      "minLength": 1,
      "title": "Friendly Name",
      "type": "string"
    },
    "mission_id": {
      "anyOf": [
        {
          "minLength": 1,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "description": "Canonical machine-facing mission identity (ULID)",
      "title": "Mission Id"
    },
    "mission_number": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "description": "Canonical mission number",
      "title": "Mission Number"
    },
    "mission_slug": {
      "description": "Canonical mission slug",
      "minLength": 1,
      "title": "Mission Slug",
      "type": "string"
    },
    "mission_type": {
      "description": "Canonical mission workflow/template type",
      "minLength": 1,
      "title": "Mission Type",
      "type": "string"
    },
    "purpose_context": {
      "description": "Short stakeholder-facing context paragraph",
      "minLength": 1,
      "title": "Purpose Context",
      "type": "string"
    },
    "purpose_tldr": {
      "description": "One-line stakeholder-facing mission summary",
      "minLength": 1,
      "title": "Purpose Tldr",
      "type": "string"
    },
    "target_branch": {
      "description": "Target branch for the mission planning artifacts",
      "minLength": 1,
      "title": "Target Branch",
      "type": "string"
    },
    "wp_count": {
      "description": "Work-package count at mission creation time",
      "minimum": 0,
      "title": "Wp Count",
      "type": "integer"
    }
  },
  "required": [
    "mission_slug",
    "mission_number",
    "mission_type",
    "target_branch",
    "wp_count",
    "friendly_name",
    "purpose_tldr",
    "purpose_context"
  ],
  "title": "MissionCreatedPayload",
  "type": "object"
}
